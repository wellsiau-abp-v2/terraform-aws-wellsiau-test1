# Terraform working directories
**/.terraform/*
**/.terraform

# State files
*.tfstate
*.tfstate.*

# Variable files (may contain sensitive data)
*.tfvars
*.tfvars.json

# Lock files (consumers generate their own)
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# IDE and OS artifacts
.DS_Store
.idea
.vscode/settings.json
